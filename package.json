{
  "name": "maxalert",
  "productName": "MaxAlert",
  "version": "0.1.3",
  "description": "MaxAlert — 포스트잇 + 코드블루 사이렌 일정 알림 앱 (Windows/Mac)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "author": "makefriends",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/makefriendscoltd-design/maxalert.git"
  },
  "build": {
    "appId": "com.makefriends.maxalert",
    "productName": "MaxAlert",
    "files": [
      "main.js",
      "preload.js",
      "lib/**",
      "renderer/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github",
      "owner": "makefriendscoltd-design",
      "repo": "maxalert-releases"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "electron-updater": "^6.8.9"
  }
}
